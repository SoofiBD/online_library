generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  books        Book[]
  reviews      Review[]
  devices      Device[]
  createdAt    DateTime @default(now())
}

// A Book is the *generic* catalogue entry: the immutable facts about a title
// (what it is, who wrote it, its ISBN). Anything that reflects how a *user*
// feels about the book — the rating and personal notes — lives in `Review`,
// so the same Book can later be shared across users without duplicating state.
model Book {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  isbn      String?
  title     String
  author    String?
  coverPath String?
  coverColor String?
  status    BookStatus @default(WANT_TO_READ)
  tags      Tag[]      @relation("BookTags")
  reviews   Review[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Prevents the same owner from importing the same ISBN twice. NULL isbns
  // (manual entries) are treated as distinct by SQLite, so they don't clash.
  @@unique([ownerId, isbn])
  @@index([ownerId])
  @@index([ownerId, status])
}

enum BookStatus {
  WANT_TO_READ
  READING
  READ
}

// A user's personal relationship with a book: their star rating (1-5, validated
// in Zod) and free-text notes. One review per (user, book) pair.
model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  rating    Int?
  notes     String?
  progress  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
  @@index([bookId])
}

model Tag {
  id      String @id @default(cuid())
  ownerId String
  name    String
  books   Book[] @relation("BookTags")

  @@unique([ownerId, name])
}

// --- Phase 2: Multi-device sync ---

// Tracks paired devices (phone, tablet, another PC) that belong to an owner.
// Created during the pairing flow; used by DeviceAuthProvider to resolve identity.
model Device {
  id         String   @id @default(cuid())
  deviceId   String   @unique // client-generated fingerprint (localStorage UUID)
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  name       String?  // human-readable: "iPhone 15", "Chrome on MacBook"
  pairedAt   DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([ownerId])
}

// Append-only change log for cross-device sync. Each mutation (create/update/
// delete) on Book, Review, or Tag produces one event. Clients pull events
// newer than their last sync timestamp; conflicts are resolved by "last write
// wins" using the `version` counter.
model SyncEvent {
  id         String   @id @default(cuid())
  ownerId    String
  entityType String   // "book" | "review" | "tag"
  entityId   String
  action     String   // "create" | "update" | "delete"
  payload    String?  // JSON diff of changed fields
  version    Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([ownerId, entityType, entityId])
}

// --- Phase 4: Public multi-user auth ---

// One-time code generated by an authenticated owner and claimed by a new
// device (see /api/pair/create, /api/pair/claim). Deleted on claim; expired
// rows are swept on each create call.
model PairingCode {
  code      String   @id
  ownerId   String
  expiresAt DateTime

  @@index([expiresAt])
}

// --- Phase 3: Book-lookup aggregator cache ---

// Stores positive and negative results from external book-lookup connectors.
// key is "isbn:<ean13>" or "text:<normalized-query>".
// hit=false means a negative cache entry (no results found).
model LookupCache {
  key       String   @id            // "isbn:<ean13>" | "text:<normalized-query>"
  kind      String                  // "isbn" | "text"
  payload   String                  // JSON-encoded LookupResult | LookupResult[]
  hit       Boolean                 // false = negative (miss) cache
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}
