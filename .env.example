DATABASE_URL="file:./data/biblio.db"
UPLOAD_DIR="./public/uploads"

# Required for signup/login sessions (Phase 2). Generate with:
# openssl rand -hex 32
AUTH_SECRET="your-random-secret"

# Required for phone-to-PC sync. Comma-separated LAN hostname(s)/IP(s) allowed to
# reach the dev server from other devices on the same Wi-Fi.
# Find your machine's IP in the `next dev` startup banner ("Network: http://<ip>:3000").
# Use the bare host only — NO protocol, NO port. Next matches allowedDevOrigins
# against the request hostname, so "http://192.168.1.42:3000" will NOT match.
# e.g. "192.168.1.42" (or "192.168.1.42,10.0.0.5").
# For production: run `next start -H 0.0.0.0 -p 3000` and use your LAN IP.
# LAN_DEV_ORIGINS="192.168.1.42"

# Production CORS allow-list for /api/*: full origins (WITH scheme, no path),
# comma-separated. This is the deployed scanner/companion client's real
# domain(s) — unlike LAN_DEV_ORIGINS this is not restricted to bare hosts or
# a fixed dev port.
# ALLOWED_ORIGINS="https://scanner.example.com,https://app.example.com"

# Optional. Enables the ISBNDB connector as a third lookup source. ISBNDB
# REQUIRES a paid API key; without it, lookups use Open Library + Google Books
# only (both keyless).
# ISBNDB_API_KEY="your-isbndb-key"

# Optional. Raises Google Books connector rate limits/quota. Without it,
# lookups fall back to Google Books' unauthenticated (lower-quota) tier.
# Get a key at https://console.cloud.google.com/apis/credentials (enable the
# "Books API"). Never commit a real key — this is a secret.
# GOOGLE_BOOKS_API_KEY="your-google-books-key"
